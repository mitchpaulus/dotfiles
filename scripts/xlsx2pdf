#!/usr/bin/env mshell
soe

args len 2 < ("Usage xlsx2pdf <input.xlsx> <output.pdf> <worksheet>" wl 0 exit) iff

# Unix paths to Windows LOCALAPPDATA and TMP.
[wslpath -u [winenv LOCALAPPDATA] *; chomp] *; chomp local-appdata!
[wslpath -u [winenv TMP] *; chomp] *; chomp tmp-dir!

# Need to get the full Windows path to a few things.
[mktemp --suffix '.xlsx' --tmpdir= @tmp-dir +]*; chomp tmpfile!
args :0: input-xlsx-param!

['cp' @input-xlsx-param @tmpfile];

[wslpath -a -w @tmpfile] *; chomp input-xlsx!
[wslpath -a -w @local-appdata "/xlsx2pdf/xlsx2pdf.ps1" +] *; chomp script-path!

args len 2 >
 # ([powershell.exe -File @script-path @input-xlsx args :2:];)
 # ([powershell.exe -File @script-path @input-xlsx];)
 ([xlsx2pdf.exe @input-xlsx args :2:];)
 ([xlsx2pdf.exe @input-xlsx];)
iff

# Move %TMP%/xlsx.pdf to the output location.
@tmp-dir "/xlsx.pdf" + tmpfile!
args :1: outputPath!

$"Moving '{@tmpfile}' to '{@outputPath}'"  wle

['mv' @tmpfile @outputPath];
