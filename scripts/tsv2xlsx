#!/usr/bin/env mshell
VER "v0.13.0"

args (a! @a "-h" = @a "--help" = or) any ("tsv2xlsx [input.tsv]\noutput.xlsx if data piped in.\n" w 0 exit) iff

args len 0 > if
    args :0: tsvfile!
    $"{@tsvfile stem}.xlsx" output!
    [xlwrite -a block A1 @tsvfile @output];
else
    [xlwrite -a block A1 "-" "output.xlsx"];
end
