#!/usr/bin/env mshell
$WSL_DISTRO_NAME? if
    ['wsl_clip']!
else* $WAYLAND_DISPLAY? *if
    ['wl-copy']! # Need wl-clipboard package sometimes.
else* runtime 'windows' = *if
    [powershell -NoProfile -Command '[Console]::InputEncoding = [Text.UTF8Encoding]::new(); Set-Clipboard -Value ([Console]::In.ReadToEnd())']!
else
    ['xclip' '-selection' 'clipboard']!
end
