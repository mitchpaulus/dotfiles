#!/usr/bin/env mshell

# PURPOSE: Quickly edit a script from the dotfiles.
# Uses 'fd' and 'fzf' to accomplish this goal.
# ['find' $"{$DOTFILES}/scripts" -type 'f'] o;
$DOTFILES toPath `scripts` / lsDir (basename str) map unlines scripts!

runtime 'windows' = if 'bat.exe' else 'lf-preview' end previewer!

[fzf $"--preview={@previewer} {$DOTFILES}/scripts/" "{}" +] @scripts < * ! chomp file!
[$EDITOR $DOTFILES toPath `scripts` @file toPath / /]!
