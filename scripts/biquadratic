#!/usr/bin/env mshell

args (a! ["-h" "--help"] (@a =) any) any if
    [
        "Usage: "
        "  biquadratic X Y [file]"
        "  biquadratic  -h"
        ""
        "  X: column number"
        "  Y: row number"
        "  file: file to read from (default: stdin)"
    ] uw
    0 exit
end

args len 3 < if "2 arguments required: X Y [file]" wle 1 exit end

args :0: x! args :1: y!
args len 3 = if $3 readFile else stdin end lines lines!

@lines :0: b0!
@lines :1: b1!
@lines :2: b2!
@lines :3: b3!
@lines :4: b4!
@lines :5: b5!

@b0 term0!
$"{@b1} * {@x}" term1!
$"{@b2} * {@x} * {@x}" term2!
$"{@b3} * {@y}" term3!
$"{@b4} * {@y} * {@y}" term4!
$"{@b5} * {@x} * {@y}" term5!

$"{@term0} + ({@term1}) + ({@term2}) + ({@term3}) + ({@term4}) + ({@term5})" wl
