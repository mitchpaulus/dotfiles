def gd (--) $DOTFILES cd end

def q (--) 0 exit end

def lf_last_dir_file (-- str)
    # This makes it work on Linux and Windows for now.
    $HOME? ($"{$HOME}/.config/lf/lf_lastdir") ($"{$LOCALAPPDATA}/msh/lf_lastdir") iff
end

def lf (--)
    ['lf' '-last-dir-path' lf_last_dir_file]?
    (lf_last_dir_file readFile cd) iff
end

def yazi (--)
    tempFile t!
    ['yazi' $"--cwd-file={@t}"]?
    (@t readFile cd) iff
end

def f (--) '.' mshFileManager end

def r (--)
    $REPOS? if $REPOS mshFileManager else 'Repos dir ($REPOS) not set.' wle end
end

def j (--)
    $JOBSDIR? if $JOBSDIR mshFileManager else 'Jobs dir ($JOBSDIR) not set.' wle end
end

def wt_cwd (--)
    $"\e]9;9;{pwd}\e\\" w
end

