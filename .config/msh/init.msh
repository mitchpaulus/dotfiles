def mshCompletion ([str] -- [str])
    input!
    ['-h' '--help' '--html' '--lex' '--parse' '--version' '-c'] options!
    ['lsp' 'bin' 'completions'] subcommands!

    @input len 0 > if
        @input :0:
        match
            "lsp": drop [], # Nothing after lsp
            "bin": drop ['add' 'remove' 'list' 'path' 'edit' 'audit' 'debug'],
            "completions": drop ['fish' 'bash' 'nushell' 'elvish'],
            _: drop [],
        end
    else
        @options @subcommands extend
    end
end
