def g (--)
  pwd [fzf-tmsu]? (drop) (cd) iff
end

def gm (--)
     $OneDriveCommercial toPath `meetingnotes` /
     path!
     @path isDir
     (@path cd)
     ($"{@path} is not a directory." wle)
     iff
end

def zip2list (a b --)
    (val2! val1! [@val1 @val2]) zip
end

